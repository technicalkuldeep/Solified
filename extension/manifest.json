{
  "manifest_version": 3,
  "name": "Solified — Verify Before You Trust",
  "version": "1.1.0",
  "description": "Solified — a real-time verification layer for Solana. Detects wallets & tokens on every page, flags scams, prevents clipboard attacks, and warns before risky transactions.",
  "permissions": ["storage", "activeTab", "clipboardRead"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Solified"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
